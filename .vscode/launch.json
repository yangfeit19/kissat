{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Kissat with Test Case",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/kissat",
            "args": [
                "${workspaceFolder}/test/cnf/and1.cnf"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "build-kissat-debug",
            "miDebuggerPath": "/usr/bin/gdb"
        },
        {
            "name": "Debug Kissat with Custom Test",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/kissat",
            "args": [
                "${input:testFile}"
            ],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "build-kissat-debug",
            "miDebuggerPath": "/usr/bin/gdb"
        },
        {
            "name": "Debug Tissat (Test Suite)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/tissat",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "build-tissat-debug",
            "miDebuggerPath": "/usr/bin/gdb"
        },
        {
            "name": "Attach to Kissat Process",
            "type": "cppdbg",
            "request": "attach",
            "program": "${workspaceFolder}/build/kissat",
            "processId": "${command:pickProcess}",
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "miDebuggerPath": "/usr/bin/gdb"
        }
    ],
    "inputs": [
        {
            "id": "testFile",
            "description": "Select a test CNF file",
            "default": "${workspaceFolder}/test/cnf/and1.cnf",
            "type": "promptString"
        }
    ]
}